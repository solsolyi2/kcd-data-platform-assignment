# ──────────────────────────────────────────────────────────────
# 로컬 개발용 환경변수 템플릿.
#  cp .env.example .env  로 복사 후 사용.
# [WHY] CLAUDE.md "시크릿 하드코딩 금지" — 실제 값은 .env(미커밋)에.
# ──────────────────────────────────────────────────────────────

DB_NAME=kcd_report
DB_USERNAME=kcd
DB_PASSWORD=kcd_local_pw

# 앱 컨테이너 외부 노출 포트
SERVER_PORT=8080

# Kafka 브로커 주소 (호스트에서 직접 실행 시는 localhost:29092)
# 컨테이너 안에서는 docker-compose가 자동 주입.
